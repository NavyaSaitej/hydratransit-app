{
  "name": "hydratransit-app",
  "version": "3.0.0",
  "description": "Multi-modal transit app for Hyderabad",
  "scripts": {
    "test": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit",
    "prepare": "husky install"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "knip": "^5.0.0",
    "oxlint": "^0.3.0",
    "@babel/preset-env": "^7.24.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,css,json,md}": [
      "prettier --write"
    ]
  }
}
